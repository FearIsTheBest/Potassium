{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "potassium",
  "version": "0.1.0",
  "identifier": "com.danny.potassium",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "potassium",
        "width": 880,
        "height": 580,
        "decorations": false,
        "minWidth": 880,
        "minHeight": 580,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$DOCUMENT/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
